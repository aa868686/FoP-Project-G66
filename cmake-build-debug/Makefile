# target to generate assembly for a file
variable.cpp.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles\FoP-Project-G66.dir\build.make CMakeFiles/FoP-Project-G66.dir/variable.cpp.s
.PHONY : variable.cpp.s

